# ============================================
# VERCEL ENVIRONMENT VARIABLES (set in Vercel dashboard)
# ============================================

# PayVia - Frontend (VITE_ prefix for checkout iframe config)
VITE_PAYVIA_MERCHANT_ID=
VITE_PAYVIA_ENVIRONMENT=production

# PayVia - Backend only (for payment processing via PayVia API)
PAYVIA_API_KEY=
PAYVIA_APP_KEY=
PAYVIA_MERCHANT_ID=
PAYVIA_ENVIRONMENT=production

# TSCheckout / TicketSocket - Backend only (events, tickets, orders)
TS_USERNAME=
TS_PASSWORD=
TS_PUBLIC_KEY=
TS_PUBLIC_KEY_SLUG=
TS_API_URL=https://clevergroup.tscheckout.com
